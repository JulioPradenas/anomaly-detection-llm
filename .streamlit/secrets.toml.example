# Streamlit Cloud secrets template.
# In Streamlit Cloud: App → Settings → Secrets, paste the lines below (without
# this comment) and your real key. NEVER commit the real secrets.toml.

GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional — defaults to llama-3.1-8b-instant. Other options:
#   "llama-3.3-70b-versatile"  (mejor calidad, algo más lento)
# GROQ_MODEL = "llama-3.1-8b-instant"
